{
  "name": "@escalated-dev/escalated-nestjs",
  "version": "1.0.0",
  "description": "Embedded helpdesk module for NestJS applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/escalated-dev/escalated-nestjs.git"
  },
  "keywords": [
    "nestjs",
    "helpdesk",
    "ticketing",
    "support",
    "sla"
  ],
  "author": "Escalated Dev",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/escalated-dev/escalated-nestjs/issues"
  },
  "homepage": "https://github.com/escalated-dev/escalated-nestjs#readme",
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "typeorm": "^0.3.0"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/event-emitter": "^2.0.0",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/throttler": "^5.0.0",
    "@nestjs/websockets": "^10.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "handlebars": "^4.7.9",
    "lodash": "^4.18.1",
    "nodemailer": "^8.0.5",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/testing": "^10.3.0",
    "@nestjs/typeorm": "^10.0.1",
    "@types/jest": "^29.5.11",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "ts-jest": "^29.1.1",
    "typeorm": "^0.3.20",
    "typescript": "^5.3.3"
  }
}
