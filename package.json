{
  "name": "@escalated-dev/escalated-nestjs",
  "version": "1.0.0",
  "description": "Embedded helpdesk module for NestJS applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/escalated-dev/escalated-nestjs.git"
  },
  "keywords": [
    "nestjs",
    "helpdesk",
    "ticketing",
    "support",
    "sla"
  ],
  "author": "Escalated Dev",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/escalated-dev/escalated-nestjs/issues"
  },
  "homepage": "https://github.com/escalated-dev/escalated-nestjs#readme",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/typeorm": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "typeorm": "^0.3.0"
  },
  "dependencies": {
    "@escalated-dev/locale": "github:escalated-dev/escalated-locale#v0.1.2",
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-socket.io": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.24",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "handlebars": "^4.7.9",
    "lodash": "^4.18.1",
    "markdown-it": "^14.1.1",
    "nestjs-i18n": "^10.5.0",
    "nodemailer": "^8.0.11",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
"reflect-metadata": "^0.2.2",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.24",
    "@nestjs/typeorm": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.8.0",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "jest-util": "^30.4.1",
    "prettier": "^3.8.4",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.4.11",
    "typeorm": "^1.0.0",
