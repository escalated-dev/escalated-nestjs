{
  "name": "@escalated-dev/escalated-nestjs",
  "version": "1.0.0",
  "description": "Embedded helpdesk module for NestJS applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/escalated-dev/escalated-nestjs.git"
  },
  "keywords": [
    "nestjs",
    "helpdesk",
    "ticketing",
    "support",
    "sla"
  ],
  "author": "Escalated Dev",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/escalated-dev/escalated-nestjs/issues"
  },
  "homepage": "https://github.com/escalated-dev/escalated-nestjs#readme",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/typeorm": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "typeorm": "^0.3.0"
  },
  "dependencies": {
    "@escalated-dev/locale": "^0.1.0",
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/websockets": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "handlebars": "^4.7.9",
    "lodash": "^4.18.1",
    "nestjs-i18n": "^10.5.0",
    "nodemailer": "^8.0.5",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.19",
    "@nestjs/typeorm": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.11",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "ts-jest": "^29.1.1",
    "typeorm": "^0.3.20",
    "typescript": "^5.3.3"
  }
